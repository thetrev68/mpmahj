  "query": "\n            INSERT INTO players (user_id, username, last_seen)\n            VALUES ($1, $2, $3)\n            ON CONFLICT (user_id) DO UPDATE\n            SET last_seen = EXCLUDED.last_seen\n            RETURNING id, username, display_name, stats, created_at, last_seen\n            ",
