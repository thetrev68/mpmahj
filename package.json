{
  "name": "mpmahj",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "American Mahjong Monorepo",
  "workspaces": [
    "apps/*",
    "!apps/client-archive-2026-01-31"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "RUST_LOG=debug cargo run -p mahjong_server",
    "dev:all": "bash scripts/dev-all.sh",
    "build:client": "npm run build --workspace=client",
    "build:server": "cargo build --release",
    "build:all": "npm run build:server && npm run build:client",
    "dev": "npm run dev:client",
    "lint": "npm run lint --workspaces --if-present",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "lint:knip": "knip",
    "lint:rust": "cargo clippy",
    "check:mojibake": "node scripts/check-mojibake.js",
    "format:rust": "cargo fmt",
    "type-check": "npm run type-check --workspace=client",
    "check:all": "npm run check:mojibake && cargo fmt -- --check && npm run type-check && npm run lint && npm run lint:rust && npm run lint:knip && npm run test",
    "test": "cargo test && npm test --workspaces --if-present",
    "coverage": "cargo tarpaulin --out Html --out Lcov && start tarpaulin-report.html",
    "coverage:html": "cargo tarpaulin --out Html && start tarpaulin-report.html",
    "coverage:lcov": "cargo tarpaulin --out Lcov",
    "bindings:generate": "cargo test -p mahjong_core export_bindings",
    "tiles:add-numbers": "node scripts/add-tile-numbers.js",
    "todo": "cargo todo 2>nul || node -e \"console.log('Install ripgrep or use: cargo todo')\"",
    "todo:all": "node scripts/find-todos.js",
    "todo:rust": "cargo todo",
    "todo:ts": "findstr /S /I /N \"TODO FIXME HACK XXX\" apps\\client\\src\\*.ts apps\\client\\src\\*.tsx 2>nul || echo No TODOs found",
    "mcp:render:bootstrap": "node scripts/render-mcp-bootstrap.mjs",
    "mcp:render:diag": "node scripts/render-mcp-bootstrap.mjs --service srv-d5c8iimr433s739f5po0",
    "prepare": "node -e \"if (process.env.CI || process.env.HUSKY === '0') process.exit(0); require('child_process').execSync('husky', { stdio: 'inherit' });\""
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^5.79.0",
    "markdownlint-cli": "^0.47.0",
    "typescript": "^5.9.3"
  }
}
