# 1. Database Connection (From Supabase -> Project Settings -> Database)
# main database url is IPv6 only. Use the session pooler url for IPv4 support.
# DATABASE_URL=postgresql://postgres:1dspeh5QXC...tmihgiff.supabase.co:5432/postgres
# SESSION_POOLER_DATABASE_URL=postgresql://postgres.fcpicgsdoo...QXCaVX8@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# 2. Supabase URL (From Supabase -> Project Settings -> API)
# This is used to automatically download public keys for token verification.
# Example: https://xyz.supabase.co
# SUPABASE_URL=https://fcpicgsdoohhtmihgiff.supabase.co
# Optional: comma-separated audiences to validate (e.g. "authenticated,project-ref")
# SUPABASE_AUDIENCE=authenticated

# 3. Server Port (Default to 3100)
# PORT=3100

# 4. AI Comparison Debug Mode (Set to 1 to enable)
# This will log AI comparison results to the console for debugging purposes.
# DEBUG_AI_COMPARISON=0

# 5. Vite Environment Variables (Prefix with VITE_)
# VITE_SUPABASE_URL=https://fcpicgsd...giff.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_Oc1j...oca-LK

# 6. WebSocket URL
# For local development: ws://localhost:3100/ws
# For production: wss://mpmahj.onrender.com/ws
# VITE_WS_URL=ws://localhost:3100/ws

# 6. Admin CSRF Protection
# Required for admin state-changing endpoint protection when credentials are used.
# Must be shared across all app instances.
# Example: 64+ character random string.
# CSRF_TOKEN=replace_with_long_random_value

# SUPABASE_ACCESS_TOKEN=sbp_e6bcb6...e3aed444f3678c

# RENDER_API_KEY=rnd_3PMfIDJ...V1nYhw
# RENDER_WORKSPACE=tea-d2b3...0ml0

# Supabase credentials
# SUPABASE_URL=https://fcp...iff.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_Oc1jCG...KZJA_hpoca-LK
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...Q.26gzrJMTaNC8sKCSVqNAo5vcMwo5it-er5U_az2_ZC4

# MCP server configuration
# MCP_SERVER_PORT=3000
# MCP_SERVER_HOST=localhost
# MCP_API_KEY=your_secret_api_key
# MCP_SERVER_URL=https://mcp.supabase.com/mcp?project_ref=fcpicgsdoohhtmihgiff
