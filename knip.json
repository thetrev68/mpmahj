{
  "ignoreDependencies": ["husky"],
  "ignoreBinaries": ["findstr", "start"],
  "ignore": [
    "crates/**",
    "**/*.md",
    "**/*.local.json",
    ".claude/**",
    ".gitignore",
    "eslint.config.js",
    "apps/client-archive-2026-01-31/**",
    "docs/archive/**"
  ],
  "workspaces": {
    "apps/client": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx,css}"],
      "ignore": [
        "src/types/bindings/**",
        "src/components/ui/**",
        "src/lib/utils.ts",
        "src/test/**",
        "**/*.test.{ts,tsx}",
        "**/*.integration.test.{ts,tsx}"
      ],
      "ignoreDependencies": ["@supabase/supabase-js", "@vitest/coverage-v8"]
    }
  }
}
