{
  "ignoreDependencies": ["husky"],
  "ignoreBinaries": ["findstr", "start"],
  "ignore": ["crates/**", "**/*.md", "**/*.local.json", ".claude/**", ".gitignore"],
  "workspaces": {
    "apps/client": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": [
        "src/types/bindings/**",
        "src/utils/**",
        "src/hooks/**",
        "src/supabase.ts",
        "src/animations/**"
