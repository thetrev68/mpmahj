{
  "ignoreDependencies": ["husky"],
  "ignoreBinaries": ["findstr", "start"],
  "ignore": [
    "crates/**",
    "**/*.md",
    "**/*.local.json",
    ".claude/**",
    ".gitignore",
    "eslint.config.js",
    "apps/client-archive-2026-01-31/**",
    "docs/archive/**"
  ],
  "workspaces": {
    "apps/client": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx,css}"],
      "ignore": ["src/types/bindings/**", "src/components/ui/**", "src/lib/utils.ts"],
      "ignoreDependencies": [
        "@radix-ui/react-dialog",
        "@radix-ui/react-select",
        "@radix-ui/react-slot",
        "@radix-ui/react-tooltip",
        "@supabase/supabase-js",
        "class-variance-authority",
        "clsx",
        "immer",
        "lucide-react",
        "tailwind-merge",
        "zustand"
      ]
    }
  }
}
