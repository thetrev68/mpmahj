{
  "ignoreDependencies": ["husky"],
  "ignoreBinaries": ["start"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignore": [
    "eslint.config.js",
    "vitest.config.ts",
    "tailwind.config.cjs",
    "scripts/add-tile-numbers.js",
    "scripts/render-mcp-bootstrap.mjs"
