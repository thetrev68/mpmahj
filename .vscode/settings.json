{
  "sarif-viewer.connectToGithubCodeScanning": "off",
  "chat.tools.terminal.autoApprove": {
    "cargo todo": true,
    "git add": true,
    "git commit": true,
    "cargo check": true,
    "npx vitest": true,
    "cargo clippy": true,
    "npx prettier": true,
    "npx tsc": true,
    "ForEach-Object": true
  },
  "knip.deferSession": true,
  "knip.requireConfig": true,
  "knip.configFilePath": "knip.json",
  "remote.autoForwardPorts": false,
  "remote.autoForwardPortsSource": "output",
  "remote.portsAttributes": {
    "*": {
      "elevateIfNeeded": true,
      "onAutoForward": "ignore"
    }
  },
  "files.watcherExclude": {
    "**/target/**": true,
    "**/node_modules/**": true,
    "**/apps/client-archive-2026-01-31/**": true,
    "**/docs/archive/**": true,
    "**/apps/client/test-results/**": true,
    "**/apps/client/playwright-report/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "search.exclude": {
    "**/target/**": true,
    "**/node_modules/**": true,
    "**/apps/client-archive-2026-01-31/**": true,
    "**/docs/archive/**": true,
    "**/apps/client/test-results/**": true,
    "**/apps/client/playwright-report/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    {
      "directory": "apps/client",
      "changeProcessCWD": true
    }
  ],
  "eslint.validate": [
    "typescript",
    "typescriptreact"
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.disableAutomaticTypeAcquisition": true,
  "markdownlint.ignore": [
    "**/node_modules/**",
    "**/target/**",
    "apps/client-archive-2026-01-31/**",
    "docs/archive/**",
    "apps/client/test-results/**",
    "apps/client/playwright-report/**"
  ],
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": false,
    "**/target": false
  },
  "chat.mcp.serverSampling": {
