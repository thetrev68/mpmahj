{
  "sarif-viewer.connectToGithubCodeScanning": "off",
  "chat.tools.terminal.autoApprove": {
    "cargo todo": true,
    "git add": true,
    "git commit": true,
    "cargo check": true
  },
  "knip.enabled": false,
  "remote.autoForwardPorts": false,
  "remote.autoForwardPortsSource": "output",
  "remote.portsAttributes": {
    "*": {
      "elevateIfNeeded": true,
      "onAutoForward": "ignore"
    }
  },
  "files.watcherExclude": {
    "**/target/**": true,
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "search.exclude": {
    "**/target/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": false,
    "**/target": false
  }
}
